# ==========================================
# DualMode Flask Starter - Server Mode (Linux / Docker)
# ==========================================

DEPLOY_MODE=server

# ==========================================
# 1. Server config
# ==========================================
APP_HOST=0.0.0.0
APP_PORT=5000

# ==========================================
# 2. MySQL database
# ==========================================
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=mysql
DB_PORT=3306
DB_NAME=dualmode_starter

# ==========================================
# 3. Redis
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# 4. Worker config
# ==========================================
MAX_WORKERS=8

# ==========================================
# 5. Admin config
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
