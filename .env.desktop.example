# ==========================================
# DualMode Flask Starter - Desktop Mode (Windows)
# ==========================================
# Desktop mode uses SQLite + in-memory queue, no MySQL or Redis needed

DEPLOY_MODE=desktop

# ==========================================
# 1. Server config
# ==========================================
APP_HOST=127.0.0.1
APP_PORT=5000

# ==========================================
# 2. Worker config
# ==========================================
MAX_WORKERS=4

# ==========================================
# 3. Admin config
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
